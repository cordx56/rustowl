{
  "name": "rustowl-vscode",
  "displayName": "RustOwl VSCode",
  "description": "Visualize ownership and lifetimes in Rust",
  "version": "0.4.0",
  "author": "cordx56 <cordx56@cordx.cx>",
  "publisher": "cordx56",
  "engines": {
    "vscode": "^1.120.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cordx56/rustowl.git"
  },
  "license": "MPL-2.0",
  "keywords": [
    "rust",
    "ownership",
    "lifetimes",
    "visualization"
  ],
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:rust"
  ],
  "icon": "rustowl-icon.png",
  "contributes": {
    "commands": [
      {
        "command": "rustowl.hover",
        "title": "Show RustOwl underline"
      },
      {
        "command": "rustowl.toggle",
        "title": "Toggle RustOwl"
      }
    ],
    "configuration": {
      "title": "rustowl",
      "properties": {
        "rustowl.underlineThickness": {
          "type": "string",
          "default": "2",
          "enum": [
            "1",
            "2",
            "3",
            "4"
          ],
          "description": "The stroke thickness of the underline line"
        },
        "rustowl.lifetimeColor": {
          "type": "string",
          "default": "hsla(125, 80%, 60%, 0.6)",
          "description": "The color of the lifetime (definitely live)"
        },
        "rustowl.maybeInitColor": {
          "type": "string",
          "default": "hsla(125, 80%, 60%, 0.6)",
          "description": "The color of the maybe initialized"
        },
        "rustowl.moveCallColor": {
          "type": "string",
          "default": "hsla(35, 80%, 60%, 0.6)",
          "description": "The color of the move/call"
        },
        "rustowl.immutableBorrowColor": {
          "type": "string",
          "default": "hsla(230, 80%, 60%, 0.6)",
          "description": "The color of the immutable borrow"
        },
        "rustowl.mutableBorrowColor": {
          "type": "string",
          "default": "hsla(300, 80%, 60%, 0.6)",
          "description": "The color of the mutable borrow"
        },
        "rustowl.outliveColor": {
          "type": "string",
          "default": "hsla(0, 80%, 60%, 0.6)",
          "description": "The color of the outlive"
        },
        "rustowl.displayDelay": {
          "type": "number",
          "default": 2000,
          "description": "Delay in displaying underlines (ms)"
        },
        "rustowl.highlightBackground": {
          "type": "boolean",
          "default": false,
          "description": "Highlight text background instead of underline"
        },
        "rustowl.defaultEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enabled by default"
        }
      }
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "run-s check-types esbuild",
    "esbuild": "node esbuild.js",
    "esbuild:prod": "pnpm run esbuild --production",
    "watch": "run-p watch:*",
    "watch:esbuild": "pnpm run esbuild --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "run-s check-types lint esbuild:prod",
    "compile-tests": "tsc",
    "watch-tests": "tsc -w --outDir out",
    "check-types": "tsc --noEmit",
    "lint": "run-s lint:oxlint lint:eslint",
    "lint:fix": "run-s lint:oxlint:fix lint:eslint:fix",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "pnpm run lint:eslint --fix",
    "lint:oxlint": "oxlint . --type-aware",
    "lint:oxlint:fix": "pnpm run lint:oxlint --fix",
    "test": "run-s compile compile-tests run-test",
    "run-test": "node out/tests/runTest.js",
    "coverage": "c8 --include=\"out/src/**/*.js\" --all --reporter=text pnpm run test",
    "fmt": "prettier -w .",
    "build": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^22.0.0",
    "@types/vscode": "^1.107.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "c8": "^12.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.1.0",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-oxlint": "^1.73.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-unicorn": "^72.0.0",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "mocha": "^11.7.6",
    "npm-run-all2": "^9.0.2",
    "ovsx": "^1.0.2",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "prettier": "^3.9.5",
    "proxyquire": "^2.1.3",
    "sinon": "^22.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "@types/vscode": "^1.125.0",
    "semver-parser": "^4.2.1",
    "vscode-languageclient": "^10.1.0",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
